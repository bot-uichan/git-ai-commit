{
  "name": "git-ai-commit",
  "version": "0.1.1",
  "packageManager": "bun@1.3.7",
  "type": "module",
  "bin": {
    "git-ai-commit": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:bun-bin": "mkdir -p bin && bun build src/cli.ts --compile --target=bun-linux-x64-modern --outfile bin/git-ai-commit",
    "prepare": "npm run build",
    "start": "tsx src/cli.ts",
    "check": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@openai/codex": "^0.107.0",
    "@openai/codex-sdk": "^0.107.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
